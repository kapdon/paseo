PASEO_BIND_HOST=127.0.0.1
PASEO_APP_PORT=8080
PASEO_DAEMON_PORT=6767
PASEO_RELAY_PORT=8787

# Public endpoints the server advertises in pairing links / browser flows.
# The app image reads PASEO_DAEMON_PUBLIC_ENDPOINT at container start, so you
# can change it without rebuilding the image.
PASEO_DAEMON_PUBLIC_ENDPOINT=localhost:6767
PASEO_RELAY_PUBLIC_ENDPOINT=localhost:8787
PASEO_APP_BASE_URL=http://localhost:8080

# Tight localhost defaults; update these when exposing beyond one machine.
PASEO_CORS_ORIGINS=http://localhost:8080
PASEO_ALLOWED_HOSTS=localhost,127.0.0.1
